rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "vamshimaddikunta7095@gmail.com";
    }

    match /walkthroughImages/{imageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blockedDates/{blockId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
